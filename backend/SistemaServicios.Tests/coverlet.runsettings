<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- Formato de salida -->
          <Format>cobertura</Format>

          <!-- Excluir código generado automáticamente por EF Core y herramientas -->
          <Exclude>
            [*]*.Migrations.*,
            [*]*AppDbContext*,
            [*]*Program*,
            [*]*AssemblyInfo*
          </Exclude>

          <!-- Incluir solo el ensamblado de la API -->
          <Include>
            [SistemaServicios.API]*
          </Include>

          <!-- Excluir atributos que marcan código generado -->
          <ExcludeByAttribute>
            Obsolete,
            GeneratedCodeAttribute,
            CompilerGeneratedAttribute
          </ExcludeByAttribute>

          <!-- No contar archivos sin líneas ejecutables -->
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
